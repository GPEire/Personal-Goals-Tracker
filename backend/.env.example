# Local development example
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_goals

# Production/staging must include sslmode=require (or verify-ca/verify-full)
# DATABASE_URL=postgresql+psycopg://<user>:<pass>@<host>:5432/<db>?sslmode=require

JWT_SECRET=change-me
FRONTEND_URL=http://localhost:5173
# Optional comma-separated list for CORS in deployed environments
# Include both production and preview frontend domains in Vercel backend project env
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend-git-*.vercel.app
ALLOWED_ORIGINS=

# development, local, test will return token in API response
ENVIRONMENT=development

# console (local/dev fallback) or resend (transactional email)
EMAIL_PROVIDER=console
EMAIL_API_KEY=
EMAIL_FROM=
